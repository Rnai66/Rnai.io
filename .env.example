FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBASE_STORAGE_BUCKET=rnai-io.appspot.com
# Local/dev fallback when Firebase Storage has not been enabled yet.
STORAGE_FALLBACK_DATA_URL=false

# Hugging Face API Token (Server-side only - keep secret)
HUGGINGFACE_API_TOKEN=your_hf_token_here
# HF_TOKEN=your_hf_token_here

# OpenRouter API Key (Server-side only - for text generation)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Together AI API Key (Server-side only - fallback text generation provider)
TOGETHER_API_KEY=your_together_api_key_here

# Google Gemini API (Server-side only - used for free dashboard chat)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Rate limiting (Upstash Redis) ──
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here

# ── Payments (Stripe) ──
STRIPE_SECRET_KEY=your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ── Media hosting (Cloudinary) ──
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here
CLOUDINARY_URL=cloudinary://key:secret@cloud_name

# ── App URL + cron secret ──
NEXT_PUBLIC_APP_URL=https://rnai-io.vercel.app
# Protects GET /api/rewards/distribute (monthly cron). Generate a long random string.
CRON_SECRET=your_long_random_cron_secret_here

# ── Self-hosted backup inference (failover when external providers are down) ──
# Deploy with mobile repo docs/reference/deploy (Modal / RunPod / docker-compose),
# then paste the resulting URLs here. Leave blank to disable a capability.
# LLM must be OpenAI-compatible; the code appends /v1/chat/completions.
#   Modal:  https://<you>--rnai-vllm-serve.modal.run
#   RunPod: https://api.runpod.ai/v2/<endpoint_id>/openai
SELF_VLLM_URL=
SELF_VLLM_MODEL=rnai-llm
SELF_SDXL_URL=
SELF_TTS_URL=
# Speech-to-text backup (Whisper / faster-whisper server exposing POST /transcribe)
SELF_STT_URL=
# Optional extra backups
SELF_REMBG_URL=
SELF_UPSCALE_URL=
# Optional bearer token sent to all self-hosted endpoints (e.g. RunPod API key)
SELF_API_KEY=
# Per-request timeout for self-hosted calls (ms)
SELF_TIMEOUT_MS=120000

# TrueMoney Gift voucher top-up (มือถือกระเป๋าเงินธุรกิจที่จะรับเงินเข้า)
TRUEMONEY_PHONE=
TRUEMONEY_CREDITS_PER_BAHT=3

# Slip verification (โอน QR แล้วอัปสลิป → บวกเครดิตอัตโนมัติ) — provider: slipok
SLIP_PROVIDER=slipok
SLIPOK_API_KEY=
SLIPOK_BRANCH_ID=
# ชื่อ/เลขบัญชีผู้รับที่ต้องตรงในสลิป (กันสลิปโอนเข้าบัญชีอื่น) เช่น 7090 หรือ ชนะ
TRUEMONEY_SLIP_RECEIVER=
